# Hetzner Cloud API token (Console → Project → Security → API Tokens, "Read" scope is enough)
HCLOUD_TOKEN=

# What to watch
SERVER_TYPE_ID=115         # 115 = CX33
LOCATION_PREFIX=nbg1       # nbg1 = Nuremberg
CHECK_INTERVAL_SECONDS=300 # poll cadence in seconds (300 = 5 min)
EMAIL_COOLDOWN_SECONDS=3600 # min seconds before a new alert can fire after one is sent (3600 = 1h); flapping within this window is suppressed

# Email alert (Resend — https://resend.com)
RESEND_API_KEY=
ALERT_EMAIL_TO=

# Optional: Hetzner Cloud project ID — when set, the "Buy now" link in alert emails
# deep-links to that project's create-server page instead of the project list.
# Find it in the console URL: https://console.hetzner.cloud/projects/<id>/...
HETZNER_PROJECT_ID=
